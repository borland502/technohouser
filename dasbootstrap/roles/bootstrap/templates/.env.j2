# XDG Spec
XDG_CONFIG_HOME="{{ xdg.config_home }}"
XDG_CACHE_HOME="{{ xdg.cache_home }}"
XDG_DATA_HOME="{{ xdg.data_home }}"
XDG_STATE_HOME="{{ xdg.state_home }}"
XDG_DATA_DIRS="{{ xdg.data_dirs }}"
XDG_CONFIG_DIRS="{{ xdg.config_dirs }}"
# XDG Spec adjacent
XDG_BIN_HOME="{{ xdg.bin_home }}"
XDG_LIB_HOME="{{ xdg.lib_home }}"

DBS_SCROOT="{{ xdg.data_home }}/automation/dasbootstrap"
DBS_WORKING_DIR="{{ xdg.data_home }}/dasbootstrap"
HOMEBREW_NO_INSTALL_CLEANUP=true
HOMEBREW_NO_ANALYTICS=1
CAN_USE_SUDO=1
HAS_ALLOW_UNSAFE=y

# Program versions
PYTHON="{{ python_ver }}"
